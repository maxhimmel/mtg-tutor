# Copy to .env.local. Both values are written to packages/backend/.env.local
# when you run `pnpm --filter @mtg-tutor/backend exec convex dev`.

# Convex client URL (queries and mutations) -- the .convex.cloud host.
NEXT_PUBLIC_CONVEX_URL=

# Convex HTTP actions URL (the streaming coach endpoint) -- the .convex.site
# host. Same deployment, different origin.
NEXT_PUBLIC_CONVEX_SITE_URL=
