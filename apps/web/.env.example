# Copy to .env.local. Every variable here is validated in app/env.ts -- a missing
# or malformed one fails the build and names itself, rather than surfacing later
# as a 500 or an app that half-works.

# --- Written to packages/backend/.env.local by `convex dev`; copy them here ---
# Convex writes provisioned values beside its own project and offers no way to
# target another directory (see `localEnvVars` in convex's convex.schema.json:
# "writes the given mapping to the local .env file"). Next only reads its own
# .env.local, so these three live in two files. Re-provisioning means updating
# both.

# The .convex.cloud host.
NEXT_PUBLIC_CONVEX_URL=

WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Must exactly match a redirect URI registered on the WorkOS environment.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Not provisioned by anything; this is the one you generate yourself -------
# Encrypts the AuthKit session cookie. 32 characters minimum.
#   openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=

# --- Optional ----------------------------------------------------------------
# The Convex HTTP actions host (the streaming coach endpoint). Derived from
# NEXT_PUBLIC_CONVEX_URL by swapping .convex.cloud for .convex.site, so set this
# only if your deployment does not follow that pairing.
# NEXT_PUBLIC_CONVEX_SITE_URL=
