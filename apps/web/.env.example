# Copy to .env.local. The Convex values are written to
# packages/backend/.env.local when you run
# `pnpm --filter @mtg-tutor/backend exec convex dev`.

# Convex client URL (queries and mutations) -- the .convex.cloud host.
NEXT_PUBLIC_CONVEX_URL=

# Convex HTTP actions URL (the streaming coach endpoint) -- the .convex.site
# host. Same deployment, different origin.
NEXT_PUBLIC_CONVEX_SITE_URL=

# WorkOS AuthKit. The client id and API key are provisioned into
# packages/backend/.env.local by `convex dev` (see packages/backend/convex.json)
# and have to be mirrored here, because Next reads its own .env.local.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Encrypts the AuthKit session cookie. Generate with: openssl rand -base64 24
# Must be at least 32 characters.
WORKOS_COOKIE_PASSWORD=

# Must match a redirect URI configured on the WorkOS environment.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
