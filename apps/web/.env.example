# Copy to .env.local. Every variable here is validated in app/env.ts -- a missing
# or malformed one fails the build and names itself, rather than surfacing later
# as a 500 or an app that half-works.

# --- Usually you do not need to set these locally ---------------------------
# next.config.ts folds in packages/backend/.env.local for anything not already
# set, and `convex dev` writes these three there. Set them here only to override.
#
# NEXT_PUBLIC_CONVEX_URL=            # the .convex.cloud host
# WORKOS_CLIENT_ID=
# WORKOS_API_KEY=
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=   # http://localhost:3000/callback

# --- You do need to set this -------------------------------------------------
# Encrypts the AuthKit session cookie. Not provisioned by Convex, so it has no
# other source. Generate with: openssl rand -base64 32   (32 chars minimum)
WORKOS_COOKIE_PASSWORD=

# --- Optional ----------------------------------------------------------------
# The Convex HTTP actions host (the streaming coach endpoint). Derived from
# NEXT_PUBLIC_CONVEX_URL by swapping .convex.cloud for .convex.site, so set this
# only if your deployment does not follow that pairing.
# NEXT_PUBLIC_CONVEX_SITE_URL=
