{
  "name": "@mtg-tutor/cli",
  "version": "0.1.0",
  "description": "Interactive MTG draft trainer CLI with 17Lands-based scoring",
  "private": true,
  "type": "module",
  "bin": {
    "mtg-tutor": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "draft": "tsx src/services/draft/main.ts",
    "review": "tsx src/services/review/main.ts",
    "stats": "tsx src/services/stats/main.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify-data": "tsx scripts/verify-data.ts",
    "smoke-draft": "tsx scripts/smoke-draft.ts"
  },
  "engines": {
    "node": ">=20.12"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@clack/core": "^0.3.4",
    "@clack/prompts": "^0.7.0",
    "@mtg-tutor/backend": "workspace:^",
    "@mtg-tutor/core": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "better-sqlite3": "^11.3.0",
    "cli-table3": "^0.6.5",
    "convex": "^1.17.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
