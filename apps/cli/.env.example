# The Convex deployment the CLI drives. Use your dev deployment for quick
# testing -- pointing this at production writes production data and spends the
# production Anthropic key on every run. Copy the value from
# packages/backend/.env.local after `convex dev` has linked a project.
CONVEX_URL=

# Optional. The deployed backend holds its own key for coaching; this is only
# used by the local fallback path.
# ANTHROPIC_API_KEY=

# Optional — override the coaching model (default: claude-sonnet-5).
# ANTHROPIC_MODEL=claude-sonnet-5
