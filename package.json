{
  "name": "mtg-tutor",
  "version": "0.1.0",
  "description": "Interactive MTG draft trainer with 17Lands-based scoring",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "pnpm --filter @mtg-tutor/cli dev",
    "draft": "pnpm --filter @mtg-tutor/cli draft",
    "review": "pnpm --filter @mtg-tutor/cli review",
    "stats": "pnpm --filter @mtg-tutor/cli stats",
    "verify-data": "pnpm --filter @mtg-tutor/cli verify-data",
    "smoke-draft": "pnpm --filter @mtg-tutor/backend smoke-draft",
    "login": "pnpm --filter @mtg-tutor/cli login",
    "build-set-stats": "pnpm --filter @mtg-tutor/backend build-set-stats",
    "seed-set-stats": "pnpm --filter @mtg-tutor/backend seed-set-stats",
    "check-availability": "pnpm --filter @mtg-tutor/backend check-availability"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
