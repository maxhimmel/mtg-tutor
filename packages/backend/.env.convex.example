# Deployment environment variables -- the ones Convex functions read via
# process.env. These do NOT live in .env.local: functions run on Convex's
# infrastructure, so they can only ever see variables set on the deployment.
#
# Workflow:
#   pnpm --filter @mtg-tutor/backend env:pull   # deployment -> .env.convex
#   $EDITOR packages/backend/.env.convex        # edit values
#   pnpm --filter @mtg-tutor/backend env:push   # .env.convex -> deployment
#
# env:push targets your dev deployment. For production, run
# `npx convex env set --prod --force --from-file .env.convex` deliberately --
# there is no script for it, so prod is never a typo away.
#
# .env.convex is gitignored because env:pull writes real secret values into it.
# Copy this file to get started.

# --- Model provider -----------------------------------------------------------
# anthropic (default, used by prod) | openai-compatible
LLM_PROVIDER=openai-compatible

# Only read when LLM_PROVIDER=openai-compatible.
# Groq: https://api.groq.com/openai/v1   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.groq.com/openai/v1
# Enumerate real ids with: curl $LLM_BASE_URL/models -H "Authorization: Bearer $KEY"
# On Groq only the gpt-oss models accept json_schema, which review.ts needs.
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=gsk_replace_me
# Set to false only for an endpoint stuck on legacy json_object mode.
# LLM_JSON_SCHEMA=true

# --- Anthropic ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace-me
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Auth (managed by convex.json authKit config; usually leave alone) --------
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_ENVIRONMENT_ID=
