{
  "name": "@mtg-tutor/backend",
  "version": "0.1.0",
  "description": "Convex backend: set ingestion, draft sessions, coaching stream",
  "private": true,
  "type": "module",
  "main": "./convex/_generated/api.js",
  "types": "./convex/_generated/api.d.ts",
  "exports": {
    ".": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    }
  },
  "scripts": {
    "dev": "convex dev",
    "build": "node scripts/codegen.mjs",
    "deploy": "convex deploy",
    "typecheck": "tsc --noEmit -p convex/tsconfig.json",
    "smoke-draft": "node scripts/smoke-draft.mjs",
    "new-set": "node scripts/new-set.mjs",
    "build-set-stats": "node scripts/build-set-stats.mjs",
    "seed-set-stats": "node scripts/seed-set-stats.mjs",
    "ingest-sets": "node scripts/ingest-sets.mjs",
    "check-availability": "node scripts/check-set-availability.mjs",
    "validate-set-stats": "node scripts/validate-set-stats.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4",
    "@ai-sdk/openai-compatible": "^3",
    "@mtg-tutor/core": "workspace:*",
    "ai": "^7",
    "convex": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
